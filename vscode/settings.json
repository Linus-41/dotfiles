{
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[python]": {
    "editor.defaultFormatter": "ms-python.autopep8",
    "editor.formatOnType": true
  },
  "bootstrapIntelliSense.version": "Bootstrap v5.3",
  "editor.accessibilitySupport": "off",
  "editor.fontFamily": "JetBrainsMono Nerd Font",
  "editor.fontLigatures": true,
  "editor.fontSize": 13,
  "editor.fontWeight": "normal",
  "editor.indentSize": "tabSize",
  "editor.minimap.enabled": false,
  "explorer.confirmPasteNative": false,
  "files.autoSave": "afterDelay",
  "python.analysis.completeFunctionParens": true,
  "remote.SSH.remotePlatform": {
    "oracle-vm": "linux",
    "unraid": "linux"
  },
  "terminal.integrated.defaultProfile.windows": "Git Bash",
  "terminal.integrated.env.osx": {
    "CW_NEW_SESSION": "1",
    "FIG_NEW_SESSION": "1",
    "Q_NEW_SESSION": "1"
  },
  "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font",
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.fontWeight": "normal",
  "terminal.integrated.macOptionIsMeta": true,
  "window.restoreWindows": "none",
  "workbench.colorCustomizations": {
    "gitDecoration.ignoredResourceForeground": "#848505",
    "editor.selectionBackground": "#82828293",
    "editor.selectionHighlightBackground": "#82828293",
    "editor.findMatchBackground": "#82828293"
  },
  "workbench.colorTheme": "React Theme",
  "workbench.editor.empty.hint": "hidden",
  "workbench.startupEditor": "none",
  "workbench.tree.indent": 25,

  "vscode_custom_css.imports": [
        "file:///Users/lwiding/dotfiles/vscode/vscode-custom-css.css",
        "file:///Users/lwiding/dotfiles/vscode/vscode-custom-js.js",
    ],
    "explorer.fileNesting.patterns": {
      "*.ts": "${capture}.js",
      "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
      "*.jsx": "${capture}.js",
      "*.tsx": "${capture}.ts",
      "tsconfig.json": "tsconfig.*.json",
      "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb",
      "*.sqlite": "${capture}.${extname}-*",
      "*.db": "${capture}.${extname}-*",
      "*.sqlite3": "${capture}.${extname}-*",
      "*.db3": "${capture}.${extname}-*",
      "*.sdb": "${capture}.${extname}-*",
      "*.s3db": "${capture}.${extname}-*"
    },
    "security.workspace.trust.untrustedFiles": "open",
    "database-client.autoSync": true,
    "yaml.schemas": {
      "file:///Users/linuswiding/.vscode/extensions/atlassian.atlascode-4.0.8/resources/schemas/pipelines-schema.json": "bitbucket-pipelines.yml"
    },
    "redhat.telemetry.enabled": true,
    "explorer.confirmDelete": false,
    "[css]": {
      "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "editor.quickSuggestions": {
      "other": "off"
    },
}